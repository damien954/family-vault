# ─────────────────────────────────────────────
# FamilyVault Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Database
DB_NAME=familyvault
DB_USER=familyvault
DB_PASSWORD=change_this_to_a_strong_password

# JWT secret — use a long random string
# Generate one with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_string

# The URL the frontend is accessible from (used for CORS)
FRONTEND_URL=http://localhost

# Port to expose the web UI on (default: 80)
PORT=80
